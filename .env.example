# Discord application and bot settings
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=

# Optional: register slash commands instantly in one test server.
# Leave blank for global commands, which can take up to about an hour to appear.
DISCORD_GUILD_ID=

# Public HTTPS URL that Discord loads for the Activity.
PUBLIC_ACTIVITY_URL=https://jackbox.example.com

# Bot/web service settings
BOT_IMAGE=jackbox-in-discord-bot:latest
BOT_CONTAINER_NAME=jackbox-discord-bot
BOT_PORT=3000
PUBLIC_HTTP_PORT=3000
STEAM_INTERNAL_URL=http://steam:3000
STEAM_PROXY_PREFIX=/steam/

# Activity invite lifetime. 86400 = 24 hours, 0 = never expire.
INVITE_MAX_AGE_SECONDS=86400

# Steam container settings
STEAM_IMAGE=jackbox-steam-webtop:latest
STEAM_CONTAINER_NAME=jackbox-steam
STEAM_TITLE=Jackbox Steam
STEAM_INTERNAL_PORT=3000
STEAM_INTERNAL_HTTPS_PORT=3001
TZ=America/New_York
PUID=1000
PGID=1000
STEAM_SHM_SIZE=2gb
STREAM_WIDTH=1920
STREAM_HEIGHT=1080
STREAM_FRAMERATE=60
SELKIES_AUDIO_ENABLED=true
SELKIES_GAMEPAD_ENABLED=true
SELKIES_CLIPBOARD_ENABLED=true
SELKIES_ENCODER=x264enc,jpeg
SELKIES_USE_CPU=true
DISABLE_DRI3=true
DISABLE_ZINK=true
MAX_RES=1920x1080
START_DOCKER=false
STEAM_AUTO_START=true
STEAM_START_DELAY_SECONDS=12
STEAM_ARGS=-silent
AUTO_OPEN_JACKBOX_INSTALLERS=false
AUTO_INSTALL_DELAY_SECONDS=90

# Set these to true only when the host supports the matching GPU override.
PIXELFLUX_WAYLAND=false
AUTO_GPU=false

# Optional HTTP basic auth for the proxied Steam desktop.
# Leaving these blank is easiest for Discord Activity use, but only do that
# behind a private/unlisted domain or a trusted reverse proxy.
STEAM_WEB_USER=
STEAM_WEB_PASSWORD=

# Jackbox Steam app IDs used by the desktop "Install Jackbox Packs" launcher.
# Pack 1-11 plus The Jackbox Party Starter.
STEAM_APP_IDS=331670 397460 434170 610180 774461 1005300 1211630 1552350 1755580 1850960 2216830 3364070
